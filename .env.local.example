# ============================================================
# PORTALE GLV — Variabili d'ambiente
# Copia questo file in .env.local e inserisci i valori reali.
# MAI committare .env.local su Git.
# ============================================================

# ── DATABASE (Neon PostgreSQL) ──────────────────────────────
# Trova in: console.neon.tech → tuo progetto → Connection string
# Formato: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# ── AUTENTICAZIONE (JWT) ────────────────────────────────────
# Stringa segreta casuale (min 32 caratteri).
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# ── STRIPE ──────────────────────────────────────────────────
# Trova in: dashboard.stripe.com → Developers → API Keys
# Usa sk_test_... per test, sk_live_... per produzione
STRIPE_SECRET_KEY=

# Webhook secret: creato quando registri il webhook su Stripe
# Dashboard Stripe → Developers → Webhooks → Add endpoint
# Endpoint URL: https://portale.grecolatinovivo.it/api/stripe/webhook
# Eventi da ascoltare: checkout.session.completed, customer.subscription.updated,
#                      customer.subscription.deleted, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=

# ── 6 PRICE ID STRIPE ───────────────────────────────────────
# ATTENZIONE: usa ESATTAMENTE questi nomi — il codice li cerca con questi nomi precisi.
# NON usare STRIPE_PRICE_MONTHLY / STRIPE_PRICE_ANNUAL (nomi sbagliati, non funzionano).
#
# Crea i prodotti su: dashboard.stripe.com → Product Catalog → + Add product
#   Piano Cultura:    €5,90/mese | €49/anno  | trial 7gg
#   Piano Linguae:    €12,90/mese | €99/anno  | trial 7gg
#   Piano Accademia:  €19,90/mese | €179/anno | trial 7gg
#
STRIPE_PRICE_CULTURA_MONTHLY=
STRIPE_PRICE_CULTURA_ANNUAL=
STRIPE_PRICE_LINGUAE_MONTHLY=
STRIPE_PRICE_LINGUAE_ANNUAL=
STRIPE_PRICE_ACCADEMIA_MONTHLY=
STRIPE_PRICE_ACCADEMIA_ANNUAL=

# ── RESEND (Email transazionali) ────────────────────────────
# Trova in: resend.com → API Keys
RESEND_API_KEY=

# Email mittente verificata su Resend (es. noreply@grecolatinovivo.it)
RESEND_FROM_EMAIL=noreply@grecolatinovivo.it

# ── APP ──────────────────────────────────────────────────────
# URL pubblico del portale (senza slash finale)
# ATTENZIONE: deve essere l'URL del PORTALE, non del sito principale www.grecolatinovivo.it
NEXT_PUBLIC_APP_URL=https://portale.grecolatinovivo.it

# In sviluppo locale usa:
# NEXT_PUBLIC_APP_URL=http://localhost:3000
