// prisma/schema.prisma — Schema del database GrecoLatinoVivo
// Provider: Neon PostgreSQL
// Aggiorna con: npx prisma db push

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Utenti registrati al portale
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  fullName     String?
  passwordHash String
  isSuspended  Boolean  @default(false)  // true = admin ha bloccato l'account
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  subscriptions        Subscription[]
  purchases            Purchase[]
  lessonProgress       LessonProgress[]
  certificates         Certificate[]
  passwordResetTokens  PasswordResetToken[]
}

// Corsi disponibili nel catalogo
model Course {
  id          String   @id @default(cuid())
  slug        String   @unique
  lang        String   // "Latino" | "Greco Antico" | ecc.
  level       String   // "A1.1" | "A1.2" | "base" | "intermedio" | "avanzato"
  title       String
  description String   @db.Text
  priceEur    Int      // Prezzo in centesimi (es. 13000 = €130)
  isNew         Boolean  @default(false)
  isAvailable   Boolean  @default(true)   // false = "coming soon" nel catalogo
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())

  // Scadenza accesso da abbonamento (null = nessuna scadenza)
  // Non influisce mai sugli acquisti singoli (Purchase).
  expiresAt            DateTime? // data oltre la quale l'abbonato perde l'accesso
  availableUntilLabel  String?   // es. "Disponibile fino al 30 giugno 2025"

  lessons        Lesson[]
  purchases      Purchase[]
  lessonProgress LessonProgress[]
  certificates   Certificate[]
}

// Lezioni appartenenti a un corso
model Lesson {
  id          String  @id @default(cuid())
  courseId    String
  title       String
  durationMin Int
  isFree      Boolean @default(false)
  sortOrder   Int
  vimeoUrl    String?

  course         Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessonProgress LessonProgress[]
}

// Abbonamenti Stripe attivi o cessati
model Subscription {
  id                   String   @id @default(cuid())
  userId               String
  plan                 String   // Uno dei 6 planId: cultura-mensile, cultura-annuale, ecc.
  stripeSubscriptionId String   @unique
  stripeCustomerId     String
  status               String   // "active" | "canceled" | "past_due"
  cancelAtPeriodEnd    Boolean  @default(false) // true = annullato ma attivo fino a currentPeriodEnd
  currentPeriodEnd     DateTime
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Acquisti singoli di corsi
model Purchase {
  id              String   @id @default(cuid())
  userId          String
  courseId        String
  stripePaymentId String   @unique
  createdAt       DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

// Tracking progressi: una riga per ogni lezione vista dall'utente
model LessonProgress {
  id             String    @id @default(cuid())
  userId         String
  lessonId       String
  courseId       String
  watchedSeconds Int       @default(0)  // secondi guardati cumulativi
  totalSeconds   Int       @default(0)  // durata totale del video (in secondi)
  completed      Boolean   @default(false) // true se watchedSeconds >= totalSeconds * 0.9
  completedAt    DateTime?              // timestamp del primo completamento
  resumeAt       Int       @default(0)  // secondi da cui riprendere la prossima volta
  updatedAt      DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

// Attestati emessi — uno per utente/corso, con codice univoco verificabile
model Certificate {
  id         String    @id @default(cuid())
  certCode   String    @unique  // es. "GLV-2025-A3B7F2C1" — codice per verifica pubblica
  userId     String
  courseId   String
  issuedAt   DateTime  @default(now())
  revokedAt  DateTime?            // null = attivo | non-null = revocato dall'admin
  revokedBy  String?              // email admin che ha revocato

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])   // un solo attestato per coppia utente+corso
}

// Token monouso per impostare la password dopo il primo pagamento
// Generato dal webhook Stripe alla creazione dell'account, valido 48 ore.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?            // null = non ancora usato
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

// Audit trail di tutte le azioni admin — non cancellabile, append-only
model AdminLog {
  id         String   @id @default(cuid())
  adminEmail String              // email dell'admin che ha agito
  action     String              // es. "REVOKE_CERT" | "RESTORE_CERT" | "SET_EXPIRY" | "SUSPEND_USER"
  targetType String              // "certificate" | "course" | "user" | "subscription"
  targetId   String              // ID dell'entità modificata
  payload    String?  @db.Text  // JSON con i dettagli dell'azione (before/after)
  createdAt  DateTime @default(now())
}
