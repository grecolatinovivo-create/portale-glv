// prisma/schema.prisma — Schema del database GrecoLatinoVivo
// Provider: Neon PostgreSQL
// Aggiorna con: npx prisma db push

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Utenti registrati al portale
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  fullName     String?
  passwordHash String
  isSuspended  Boolean  @default(false)  // true = admin ha bloccato l'account
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Preferenze onboarding — salvate nel DB per sincronizzare tutti i dispositivi
  onboardingDone Boolean @default(false)  // true = quiz già compilato (anche se saltato)
  prefLang       String? // es. "Latino" | "Greco Antico" | null = non specificato
  prefLevel      String? // es. "beginner" | "elementary" | "intermediate" | "teacher"
  prefGoal       String? // es. "lettura" | "esami" | "cultura" | ecc.

  subscriptions        Subscription[]
  purchases            Purchase[]
  lessonProgress       LessonProgress[]
  certificates         Certificate[]
  passwordResetTokens  PasswordResetToken[]
  vocabulary           Vocabulary[]
  favorites            Favorite[]
  examBookings         ExamBooking[]
  liveBookings         LiveBooking[]
  classrooms           Classroom[]  @relation("TeacherClassrooms")
}

// Corsi disponibili nel catalogo
model Course {
  id          String   @id @default(cuid())
  slug        String   @unique
  lang        String   // "Latino" | "Greco Antico" | ecc.
  level       String   // "A1.1" | "A1.2" | "base" | "intermedio" | "avanzato"
  title       String
  description String   @db.Text
  priceEur    Int      // Prezzo in centesimi (es. 13000 = €130)
  isNew         Boolean  @default(false)
  isAvailable   Boolean  @default(true)   // false = "coming soon" nel catalogo
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())

  // Tier minimo richiesto per accedere tramite abbonamento.
  // Gerarchia: cultura < linguae < accademia
  // null = accessibile a tutti (corsi gratuiti/preview)
  // Non influisce mai sugli acquisti singoli (Purchase).
  tierRequired         String?   @default("cultura") // 'cultura' | 'linguae' | 'accademia' | null

  // Scadenza accesso da abbonamento (null = nessuna scadenza)
  // Non influisce mai sugli acquisti singoli (Purchase).
  expiresAt            DateTime? // data oltre la quale l'abbonato perde l'accesso
  availableUntilLabel  String?   // es. "Disponibile fino al 30 giugno 2025"

  // ── Dati per l'ATTESTATO (template latin-cert) ───────────────────────────
  // Compilati dall'admin. Le date "dal…al…" NON stanno qui: sono per-studente,
  // calcolate dai progressi reali (inizio = primo accesso, fine = completamento).
  sofiaCode    String?   // codice SOFIA/MIM del corso (es. "149224")
  courseHours  Int?      // durata complessiva in ore (es. 4)
  isWebinar    Boolean  @default(false)  // true = webinar (Cultura, ~1h); va nella sezione Webinar

  lessons        Lesson[]
  purchases      Purchase[]
  lessonProgress LessonProgress[]
  certificates   Certificate[]
  resources      CourseResource[]
  exercises      ExerciseTest[]
  favorites      Favorite[]
}

// Lezioni appartenenti a un corso
model Lesson {
  id           String  @id @default(cuid())
  courseId     String
  title        String
  durationMin  Int
  isFree       Boolean @default(false)
  sortOrder    Int
  vimeoUrl     String?
  vimeoStatus  String?           // null | 'processing' | 'ready' | 'error' — stato transcoding Vimeo
  description  String? @db.Text  // descrizione/note della lezione (opzionale, editabile da admin)
  latinCertId  Int?    @unique  // IDL originale da latin-cert (per mapping risorse)

  // Contesto per il pannello AI (metodo induttivo-contestuale)
  // Popolati dal docente/admin — permettono al Magistro di generare esercizi
  // veramente legati al contenuto della lezione, non generici.
  textFragment       String? @db.Text   // Testo autentico/pseudoautentico usato nella lezione
  contentSummary     String? @db.Text   // Descrizione breve del contenuto (3-5 frasi)
  keyVocabulary      Json?              // Array [{term, meaning, notes?}] — max 15 voci
  learningObjectives String? @db.Text   // Cosa lo studente capisce/sa fare dopo la lezione

  course         Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessonProgress LessonProgress[]
  resources      LessonResource[]
  exercises      ExerciseTest[]
}

// Materiali scaricabili a livello di corso (PDF, slide, esercizi...)
// Migrati da /classroomresources/{IDCR}/ su latin-cert via FTP → Vercel Blob
model CourseResource {
  id        String   @id @default(cuid())
  courseId  String
  title     String               // nome file leggibile (es. "LEZIONE 04 11")
  filename  String               // nome file originale
  blobUrl   String?              // URL Vercel Blob (private)
  fileType  String   @default("pdf")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

// Risorse scaricabili collegate a una lezione (PDF, documenti, materiali)
// Migrate da classroomresources/ di latin-cert via FTP → Vercel Blob (private)
model LessonResource {
  id          String   @id @default(cuid())
  lessonId    String
  title       String               // titolo della risorsa (nome file pulito o consegna)
  filename    String               // nome file originale (es. "esercizi_lezione1.pdf")
  blobUrl     String?              // URL Vercel Blob (private) — usato per il download
  fileType    String   @default("pdf")  // "pdf" | "image" | "audio" | "other"
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

// Abbonamenti Stripe attivi o cessati
model Subscription {
  id                   String   @id @default(cuid())
  userId               String
  plan                 String   // Uno dei 6 planId: cultura-mensile, cultura-annuale, ecc.
  stripeSubscriptionId String   @unique
  stripeCustomerId     String
  status               String   // "active" | "canceled" | "past_due"
  cancelAtPeriodEnd    Boolean  @default(false) // true = annullato ma attivo fino a currentPeriodEnd
  currentPeriodEnd     DateTime
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Acquisti singoli di corsi
model Purchase {
  id              String   @id @default(cuid())
  userId          String
  courseId        String
  stripePaymentId String   @unique
  createdAt       DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

// Tracking progressi: una riga per ogni lezione vista dall'utente
model LessonProgress {
  id             String    @id @default(cuid())
  userId         String
  lessonId       String
  courseId       String
  watchedSeconds Int       @default(0)  // secondi guardati cumulativi
  totalSeconds   Int       @default(0)  // durata totale del video (in secondi)
  completed      Boolean   @default(false) // true se watchedSeconds >= totalSeconds * 0.9
  completedAt    DateTime?              // timestamp del primo completamento
  resumeAt       Int       @default(0)  // secondi da cui riprendere la prossima volta
  updatedAt      DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

// Attestati emessi — uno per utente/corso, con codice univoco verificabile
model Certificate {
  id         String    @id @default(cuid())
  certCode   String    @unique  // es. "GLV-2025-A3B7F2C1" — codice per verifica pubblica
  userId     String
  courseId   String
  issuedAt   DateTime  @default(now())
  revokedAt  DateTime?            // null = attivo | non-null = revocato dall'admin
  revokedBy  String?              // email admin che ha revocato

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])   // un solo attestato per coppia utente+corso
}

// Preferiti — corsi salvati dall'utente dalla pagina corso
// La stellina è disponibile nella pagina corso (accanto al titolo).
// Saved in DB so they sync across devices.
model Favorite {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])   // un solo preferito per coppia utente+corso
  @@index([userId])
}

// Token monouso per impostare la password dopo il primo pagamento
// Generato dal webhook Stripe alla creazione dell'account, valido 48 ore.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?            // null = non ancora usato
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

// Vocabolario personale — parole aggiunte dall'utente durante lo studio
// Sistema di ripasso a intervalli crescenti (spaced repetition leggera):
// intervalli: 1 → 3 → 7 → 14 → 30 giorni (easeFactor 1–5)
model Vocabulary {
  id          String    @id @default(cuid())
  userId      String
  courseId    String?   // corso da cui è stata aggiunta la parola (opzionale)
  lessonId    String?   // lezione da cui è stata aggiunta (opzionale)

  // Contenuto
  term        String    @db.Text  // parola o espressione in lingua originale
  translation String    @db.Text  // traduzione/significato
  context     String?   @db.Text  // frase di contesto (opzionale)
  lang        String?              // es. 'Latino', 'Greco Antico'

  // SRS (Spaced Repetition System)
  easeFactor  Int       @default(3)   // 1–5, quanto è facile questa parola
  interval    Int       @default(1)   // giorni fino al prossimo ripasso
  nextReview  DateTime  @default(now()) // quando ripassare
  reviewCount Int       @default(0)   // quante volte ripassata
  lastResult  String?                  // 'easy' | 'good' | 'hard' | 'again'
  lastReviewAt DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, nextReview])
  @@index([userId, lang])
}

// ─── ESERCIZI AUTOCORRETTIVI ────────────────────────────────────────────────
// Migrati dal database latin-cert.org (tabelle: test, section, quiz_list +
// SceltaMultipla, VeroFalso, ClozeDragDrop, ClozeSceltaMultipla,
// Completamento, Abbinamento, RiordinoTesto, RispostaAperta)

// Un test = una serie di esercizi (può essere collegato a un corso o standalone)
model ExerciseTest {
  id          String   @id @default(cuid())
  latinCertId Int      @unique   // IDT originale da latin-cert
  title       String
  description String?  @db.Text
  isPublic    Boolean  @default(false)
  assignableByTeachers Boolean @default(false)  // true = i docenti possono assegnarlo alle classi (curato dall'admin)
  lingua      String?             // "Latino" | "Greco Antico"
  livello     String?             // "A1.1" | "B1" ecc.
  metodo      String?             // "Induttivo-contestuale" ecc.
  ordine      Int      @default(100)
  courseId    String?             // collegato a un corso Neon (opzionale)
  lessonId    String?             // collegato a una lezione specifica (da lezione.FK_IDT)
  createdAt   DateTime @default(now())

  course   Course?           @relation(fields: [courseId], references: [id], onDelete: SetNull)
  lesson   Lesson?           @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  sections ExerciseSection[]
  classroomAssignments ClassroomTest[]
}

// Una sezione all'interno di un test
model ExerciseSection {
  id          String @id @default(cuid())
  latinCertId Int    @unique   // IDS originale
  testId      String
  name        String
  timeMinutes Int    @default(5)
  sortOrder   Int    @default(0)

  test      ExerciseTest       @relation(fields: [testId], references: [id], onDelete: Cascade)
  questions ExerciseQuestion[]
}

// Una singola domanda/attività all'interno di una sezione.
// Il campo `data` (JSON) contiene la struttura specifica per ogni tipo.
//
// Tipi (questionType):
//   SceltaMultipla   → data: [{question, correct, wrong_1, wrong_2, wrong_3?}, ...]
//   VeroFalso        → data: [{question, correct: 0|1}, ...]
//   ClozeDragDrop    → data: {html}  (testo con <span class="completamento">risposta</span>)
//   ClozeSceltaMultipla → data: {html}  (span con attr incorrect/incorrect2)
//   Completamento    → data: {html}  (span con <label>hint</label> per la risposta)
//   Abbinamento      → data: [{w1, w2}, ...]
//   RiordinoTesto    → data: {txt}  ({part}...{/part} markers)
//   RispostaAperta   → data: {min?, max?}
model ExerciseQuestion {
  id           String  @id @default(cuid())
  latinCertId  Int     @unique   // IDQL originale
  sectionId    String
  questionType String            // uniquename da quiz_type
  sortOrder    Int     @default(0)
  title        String? @db.Text  // titolo dell'esercizio
  instruction  String? @db.Text  // consegna per lo studente
  contextText  String? @db.Text  // testo di contesto (es. brano da leggere)
  audio        String?            // filename audio (se presente)
  image        String?            // filename immagine (se presente)
  data         Json              // dati specifici per tipo (vedi commento sopra)

  section ExerciseSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
}

// ─── ESAMI DI CERTIFICAZIONE (Linguae annuale) ──────────────────────────────
// L'admin crea sessioni d'esame (Latino/Greco) con data; gli utenti Linguae
// annuale (o superiore) vedono le date e si prenotano.
model ExamSession {
  id          String   @id @default(cuid())
  lingua      String              // "Latino" | "Greco Antico"
  livello     String?             // es. "B1", "A2" (opzionale)
  title       String              // es. "Esame di certificazione — Latino B1"
  description String?  @db.Text
  examDate    DateTime            // data e ora dell'esame
  location    String?             // "Online" | indirizzo fisico
  capacity    Int?                // posti massimi (null = illimitato)
  isOpen      Boolean  @default(true)  // false = prenotazioni chiuse
  createdAt   DateTime @default(now())

  bookings    ExamBooking[]
}

model ExamBooking {
  id         String   @id @default(cuid())
  sessionId  String
  userId     String
  status     String   @default("booked")  // "booked" | "canceled"
  createdAt  DateTime @default(now())

  session ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])  // una prenotazione per utente per sessione
}

// ─── LIVE MENSILI (Accademia annuale) ────────────────────────────────────────
// L'admin inserisce la live (data, ora, link Zoom). Gli utenti Accademia annuale
// prenotano; ricevono reminder 24h e 2h prima; l'accesso alla diretta si apre 1h prima.
model LiveSession {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  startAt     DateTime            // data e ora di inizio
  durationMin Int      @default(60)
  zoomLink    String              // link alla diretta (visibile solo da 1h prima ai prenotati)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())

  // Reminder già inviati (per evitare doppioni dal cron)
  remind24Sent Boolean @default(false)
  remind2Sent  Boolean @default(false)

  bookings    LiveBooking[]
}

model LiveBooking {
  id        String   @id @default(cuid())
  sessionId String
  userId    String
  createdAt DateTime @default(now())

  session LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
}

// ─── CLASSI E TEST PER DOCENTI (Accademia annuale) ───────────────────────────
// Replica il modello latin-cert (classroom / user2classroom / test2classroom /
// autovalSession). Il docente (abbonato Accademia annuale) crea una classe con
// codice univoco, assegna test della libreria (ExerciseTest), e gli studenti
// — SENZA account — accedono col codice, si identificano (nome/cognome/email,
// con conferma email) e svolgono i test. Il docente vede i risultati.

model Classroom {
  id        String   @id @default(cuid())
  teacherId String              // User docente proprietario
  name      String
  code      String   @unique    // codice univoco (6 caratteri) dato agli studenti
  isOpen    Boolean  @default(true)   // false = accesso studenti chiuso
  createdAt DateTime @default(now())

  teacher     User                @relation("TeacherClassrooms", fields: [teacherId], references: [id], onDelete: Cascade)
  students    ClassroomStudent[]
  assignments ClassroomTest[]
}

// Studente di una classe — NON è un User del portale: si identifica con email.
model ClassroomStudent {
  id             String    @id @default(cuid())
  classroomId    String
  firstName      String
  lastName       String
  email          String
  emailConfirmed Boolean   @default(false)
  confirmToken   String    @unique          // token per il link di conferma email
  createdAt      DateTime  @default(now())

  classroom   Classroom        @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  submissions TestSubmission[]

  @@unique([classroomId, email])   // un'iscrizione per email per classe
}

// Test (della libreria ExerciseTest) assegnato a una classe.
model ClassroomTest {
  id          String   @id @default(cuid())
  classroomId String
  testId      String              // -> ExerciseTest.id
  assignedAt  DateTime @default(now())

  classroom Classroom    @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  test      ExerciseTest @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@unique([classroomId, testId])
}

// Svolgimento di un test da parte di uno studente di classe.
model TestSubmission {
  id          String    @id @default(cuid())
  studentId   String
  testId      String              // -> ExerciseTest.id
  classroomId String
  score       Int?                // punteggio (n. risposte corrette)
  maxScore    Int?                // domande totali
  completedAt DateTime?
  startedAt   DateTime  @default(now())
  answers     Json?               // risposte dettagliate [{questionId, given, correct}]

  student   ClassroomStudent @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([classroomId, testId])
}

// ─────────────────────────────────────────────────────────────────────────────

// Audit trail di tutte le azioni admin — non cancellabile, append-only
model AdminLog {
  id         String   @id @default(cuid())
  adminEmail String              // email dell'admin che ha agito
  action     String              // es. "REVOKE_CERT" | "RESTORE_CERT" | "SET_EXPIRY" | "SUSPEND_USER"
  targetType String              // "certificate" | "course" | "user" | "subscription"
  targetId   String              // ID dell'entità modificata
  payload    String?  @db.Text  // JSON con i dettagli dell'azione (before/after)
  createdAt  DateTime @default(now())
}
